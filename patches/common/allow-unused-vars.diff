+++ code-editor-src/src/tsconfig.base.json
@@ -6,7 +6,7 @@
 		"experimentalDecorators": true,
 		"noImplicitReturns": true,
 		"noImplicitOverride": true,
-		"noUnusedLocals": true,
+		"noUnusedLocals": false,
 		"noUncheckedSideEffectImports": true,
 		"allowUnreachableCode": false,
 		"strict": true,
