Fix TypeScript rootDir for shared webpack config

Adds explicit rootDir '.' to the shared webpack TypeScript loader options
to prevent build errors when extensions are compiled from different paths.

Index: code-editor-src/extensions/shared.webpack.config.mjs
===================================================================
--- code-editor-src.orig/extensions/shared.webpack.config.mjs
+++ code-editor-src/extensions/shared.webpack.config.mjs
@@ -17,6 +17,7 @@ const require = createRequire(import.met
 const tsLoaderOptions = {
 	compilerOptions: {
 		'sourceMap': true,
+		'rootDir': '.',
 	},
 	onlyCompileBundledFiles: true,
 };
